{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebP Convert",
  "version": "0.1.0",
  "identifier": "com.sitisy.webp-convert",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WebP Convert",
        "width": 560,
        "height": 700,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 580
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
